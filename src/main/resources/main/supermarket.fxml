<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="580.0" prefWidth="920.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.SupermarketController">
   <center>
      <AnchorPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <TabPane layoutY="-3.0" prefHeight="580.0" prefWidth="920.0" tabClosingPolicy="UNAVAILABLE">
              <tabs>
                <Tab text="Main Menu">
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <Label layoutX="349.0" layoutY="8.0" text="Supermarket Manager">
                                 <font>
                                    <Font name="System Bold" size="21.0" />
                                 </font>
                              </Label>
                              <Button layoutX="104.0" layoutY="46.0" onAction="#addFloorArea" text="Add Floor Area" />
                              <Button fx:id="addAisleButton" layoutX="335.0" layoutY="46.0" onAction="#addAisle" text="Add Aisle" />
                              <Button fx:id="addShelfButton" layoutX="589.0" layoutY="46.0" onAction="#addShelf" text="Add Shelf" />
                              <Button fx:id="addItemButton" layoutX="34.0" layoutY="304.0" onAction="#addItem" text="Add Product" />
                              <Button fx:id="removeItemButton" layoutX="125.0" layoutY="304.0" onAction="#removeProduct" text="Remove Product" />
                              <Button layoutX="833.0" layoutY="139.0" onAction="#save" prefHeight="25.0" prefWidth="42.0" text="Save" />
                              <Button layoutX="832.0" layoutY="176.0" onAction="#clearAllData" text="Clear" />
                              <Button layoutX="832.0" layoutY="214.0" onAction="#quit" prefHeight="25.0" prefWidth="41.0" text="Quit" />
                              <ListView fx:id="floorAreaList" layoutX="104.0" layoutY="76.0" prefHeight="200.0" prefWidth="200.0" />
                              <ListView fx:id="aisleList" layoutX="335.0" layoutY="76.0" prefHeight="200.0" prefWidth="200.0" />
                              <ListView fx:id="shelfList" layoutX="589.0" layoutY="76.0" prefHeight="200.0" prefWidth="200.0" />
                              <Label layoutX="391.0" layoutY="288.0" text="Products">
                                 <font>
                                    <Font name="System Bold" size="21.0" />
                                 </font>
                              </Label>
                              <TableView fx:id="productsTable" layoutX="34.0" layoutY="337.0" prefHeight="200.0" prefWidth="831.0">
                                <columns>
                                  <TableColumn fx:id="descriptionColumn" prefWidth="111.0" text="Description" />
                                  <TableColumn fx:id="weightColumn" prefWidth="122.0" text="Weight (kg)" />
                                    <TableColumn fx:id="priceColumn" minWidth="0.0" prefWidth="135.0" text="Price (€)" />
                                    <TableColumn fx:id="quantityColumn" prefWidth="148.0" text="Quantity" />
                                    <TableColumn fx:id="temperatureColumn" minWidth="0.0" prefWidth="147.0" text="Temperature" />
                                    <TableColumn fx:id="imageColumn" prefWidth="167.0" text="Image" />
                                </columns>
                              </TableView>
                              <Button layoutX="237.0" layoutY="304.0" onAction="#smartAdd" text="Smart Add" />
                           </children>
                        </AnchorPane>
                  </content>
                </Tab>
                <Tab text="View All">
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <TextArea fx:id="stockTextArea" editable="false" layoutX="26.0" layoutY="53.0" prefHeight="480.0" prefWidth="867.0" />
                              <Button layoutX="26.0" layoutY="21.0" mnemonicParsing="false" onAction="#viewAllStock" text="View All Stock" />
                              <Label layoutX="377.0" layoutY="14.0" text="View All Stock">
                                 <font>
                                    <Font name="System Bold" size="21.0" />
                                 </font>
                              </Label>
                           </children></AnchorPane>
                  </content>
                </Tab>
                  <Tab text="Search">
                     <content>
                        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <ListView fx:id="searchList" layoutX="33.0" layoutY="71.0" prefHeight="460.0" prefWidth="864.0" />
                              <Label layoutX="424.0" layoutY="6.0" text="Search">
                                 <font>
                                    <Font name="System Bold" size="21.0" />
                                 </font>
                              </Label>
                              <Button layoutX="33.0" layoutY="37.0" mnemonicParsing="false" onAction="#searchProduct" text="Search" />
                              <Button layoutX="92.0" layoutY="37.0" mnemonicParsing="false" onAction="#clearSearch" text="Clear" />
                           </children>
                        </AnchorPane>
                     </content>
                  </Tab>
              </tabs>
            </TabPane>
         </children>
      </AnchorPane>
   </center>
</BorderPane>
